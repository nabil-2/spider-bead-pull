digraph NotebookFlow {
  graph [
    rankdir=TB,
    splines=polyline,
    newrank=true,
    pad="0.08",
    margin="0.02",
    nodesep="0.18",
    ranksep="0.24",
    size="13.333,7.5!",
    ratio="compress",
    bgcolor="__BG__",
    fontname="__FONT__",
    labelloc="t",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="22" COLOR="__TEXT__"><B>__TITLE__</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="10" COLOR="__MUTED__">__SUBTITLE__</FONT></TD></TR>
      </TABLE>
    >
  ];
  node [shape=plain, fontname="__FONT__"];
  edge [fontname="__FONT__", color="__EDGE__", penwidth="1.3", arrowsize="0.8"];

  stage1 [label=<__STAGE1_LABEL__>];
  stage2 [label=<__STAGE2_LABEL__>];
  stage3 [label=<__STAGE3_LABEL__>];
  stage4 [label=<__STAGE4_LABEL__>];
  stage5 [label=<__STAGE5_LABEL__>];
  stage6 [label=<__STAGE6_LABEL__>];

  constants [label=<__CONSTANTS_LABEL__>];
  reuse [label=<__REUSE_LABEL__>];
  outputs [label=<__OUTPUTS_LABEL__>];

  { rank=same; stage1; stage4; }
  { rank=same; stage2; stage5; }
  { rank=same; stage3; stage6; }

  stage1 -> stage2 -> stage3;
  stage3 -> stage4;
  stage4 -> stage5 -> stage6;
  stage3 -> reuse [style=dashed];
  stage2 -> outputs [style=dashed];
  stage5 -> outputs [style=dashed];
  constants -> stage1 [style=dashed, arrowhead=none];
}
