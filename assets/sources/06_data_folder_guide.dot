digraph DataGuide {
  graph [
    rankdir=TB,
    splines=polyline,
    newrank=true,
    pad="0.08",
    margin="0.02",
    nodesep="0.16",
    ranksep="0.20",
    size="13.333,7.5!",
    ratio="compress",
    bgcolor="__BG__",
    fontname="__FONT__",
    labelloc="t",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="22" COLOR="__TEXT__"><B>__TITLE__</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="10" COLOR="__MUTED__">__SUBTITLE__</FONT></TD></TR>
      </TABLE>
    >
  ];
  node [shape=plain, fontname="__FONT__"];
  edge [fontname="__FONT__", color="__EDGE__", penwidth="1.3", arrowsize="0.8"];

  tree [label=<__TREE_LABEL__>];
  legacy [label=<__LEGACY_LABEL__>];
  fits [label=<__FITS_LABEL__>];
  fullref [label=<__FULLREF_LABEL__>];
  results [label=<__RESULTS_LABEL__>];
  metrics [label=<__METRICS_LABEL__>];
  slurm [label=<__SLURM_LABEL__>];
  external [label=<__EXTERNAL_LABEL__>];

  { rank=same; legacy; fits; fullref; }
  { rank=same; results; metrics; slurm; }

  tree -> legacy;
  tree -> fits;
  tree -> fullref;
  legacy -> results [style=invis, weight=12];
  fits -> metrics [style=invis, weight=12];
  fullref -> slurm [style=invis, weight=12];
  tree -> external [style=dashed];
}
