digraph FigsGuide {
  graph [
    rankdir=TB,
    splines=polyline,
    newrank=true,
    pad="0.08",
    margin="0.02",
    nodesep="0.16",
    ranksep="0.20",
    size="13.333,7.5!",
    ratio="compress",
    bgcolor="__BG__",
    fontname="__FONT__",
    labelloc="t",
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="4">
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="22" COLOR="__TEXT__"><B>__TITLE__</B></FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT FACE="__FONT__" POINT-SIZE="10" COLOR="__MUTED__">__SUBTITLE__</FONT></TD></TR>
      </TABLE>
    >
  ];
  node [shape=plain, fontname="__FONT__"];
  edge [fontname="__FONT__", color="__EDGE__", penwidth="1.3", arrowsize="0.8"];

  tree [label=<__TREE_LABEL__>];
  diagnostics [label=<__DIAGNOSTICS_LABEL__>];
  comparisons [label=<__COMPARISONS_LABEL__>];
  configs [label=<__CONFIGS_LABEL__>];
  common [label=<__COMMON_LABEL__>];
  lines [label=<__LINES_LABEL__>];

  { rank=same; diagnostics; comparisons; configs; }
  { rank=same; common; lines; }

  tree -> diagnostics;
  tree -> comparisons;
  tree -> configs;
  configs -> common;
  configs -> lines;
}
